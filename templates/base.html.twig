<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        {# Bloc pour inclure les fichiers CSS générés par Webpack Encore #}
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}
    </head>
    
    <body>
        {# Bloc pour le contenu de l'header de la page #}
        {% block header %}
        <header>
            <ul class="dropdown-menu">
                <li><h6 class="dropdown-header">Dropdown header</h6></li>
                <li><a class="dropdown-item" href="#">Action</a></li>
                <li><a class="dropdown-item" href="#">Another action</a></li>
            </ul>
        </header>
        {% endblock %}

        {# Bloc pour le contenu de la page #}
        {% block body %}
        {% endblock %}
        
        {# Utilisation de Webpack Encore pour charger les assets JS #}
        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </body>
</html>
